# Gavl backbone — Hub B. A Reticulum transport node that PEERS with Hub A (the backbone link).
#
#   rnsd --config hub/hub-b
#
# Hub B both listens (so nodes can connect to it) AND opens a client link to Hub A. That one
# cross-link is what fuses the two hubs into a single network — only ONE side needs it. To grow the
# backbone, give each new hub a link to one existing hub (a connected graph; it need not be a full mesh).
#
# IMPORTANT: set the "Peer to Hub A" target_host to Hub A's real address — its public IP in
# production, or 127.0.0.1 if both hubs run on the same machine.

[reticulum]
  enable_transport = Yes
  share_instance = No
  instance_name = gavl-hub-b

[logging]
  loglevel = 3

[interfaces]
  [[Hub B Server]]
    type = TCPServerInterface
    interface_enabled = true
    listen_ip = 0.0.0.0
    listen_port = 5243

  [[Peer to Hub A]]
    type = TCPClientInterface
    interface_enabled = true
    target_host = 127.0.0.1
    target_port = 5242
