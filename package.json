{
  "name": "gavl",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Gavl — a decentralized peer-to-peer Bitcoin bull/bear market (matched, no pool) on a Proof-of-Space-Time cooldown ledger (Holepunch).",
  "scripts": {
    "dev": "concurrently -k -n daemon,web -c blue,magenta \"npm:daemon:dev\" \"npm:web:dev\"",
    "daemon": "node src/server.ts",
    "daemon:dev": "cross-env GAVL_VDF=hash GAVL_ORACLE_PUBLISH=1 node src/server.ts",
    "web:dev": "vite --config web/vite.config.js web",
    "web:build": "vite --config web/vite.config.js build web",
    "test": "node --test \"test/*.test.ts\"",
    "test:fast": "node --test test/intent-match.test.ts test/intent-fold.test.ts test/intent-gossip.test.ts test/consensus.test.ts test/consensus-gossip.test.ts test/ledger.test.ts test/post-cooldown.test.ts test/sync.test.ts test/custody-threshold.test.ts test/custody-bridge.test.ts",
    "test:chia": "node --test test/chia.test.ts",
    "demo": "node src/index.ts",
    "demo:consensus": "node src/demo-consensus.ts"
  },
  "engines": {
    "node": ">=23.6"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^22.0.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "svelte": "^5.56.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@scure/base": "^2.2.0",
    "@scure/btc-signer": "^2.2.0",
    "corestore": "^7.10.0",
    "hypercore": "^11.33.1",
    "hyperdht": "^6.32.0",
    "hyperswarm": "^4.17.0"
  }
}
