{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "gavl",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5180
    },
    {
      "name": "gavl-fresh",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:fresh"],
      "port": 5180
    },
    {
      "name": "gavl-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "web:dev"],
      "port": 5180
    },
    {
      "name": "gavl-web-rounds",
      "runtimeExecutable": "env",
      "runtimeArgs": ["GAVL_API=http://127.0.0.1:6441", "npm", "run", "web:dev"],
      "port": 5180
    },
    {
      "name": "gavl-daemon",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "daemon:dev"],
      "port": 6440
    }
  ]
}
